# EditorConfig — cross-editor whitespace and encoding settings.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Don't strip trailing whitespace inside Markdown — two trailing spaces
# mean "line break" in CommonMark.
trim_trailing_whitespace = false
