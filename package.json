{
  "name": "mp3-frame-counter",
  "version": "1.0.0",
  "private": true,
  "description": "HTTP API that counts MPEG-1 Audio Layer III frames in an uploaded MP3 file.",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --transpile-only --respawn src/server.ts",
    "test": "jest --runInBand",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "verify": "pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "verify:mediainfo": "node scripts/verify-mediainfo.js"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.0",
    "fastify": "^4.28.1",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
